      "exit": "on",
      "entry_cancel": "silent",
      "exit_cancel": "silent",
      "protection_trigger": "on",
      "protection_trigger_global": "on"
    }
  },
  "api_server": {
    "username": "freqtrader",
    "password": "CHANGE_THIS_PASSWORD",
    "jwt_secret_key": "CHANGE_THIS_JWT_SECRET_32_CHARS_MIN",
    "ws_token": "CHANGE_THIS_WS_TOKEN"
  }
}
